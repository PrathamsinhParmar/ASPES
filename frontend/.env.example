# ==============================================================================
# ASPES Frontend Environment Configuration
# Copy this file to .env and fill in actual values
# All variables MUST be prefixed with REACT_APP_ to be accessible in React
# ==============================================================================

# Backend API base URL
REACT_APP_API_URL=http://localhost:8000/api/v1
REACT_APP_WS_URL=ws://localhost:8000/ws

# App Info
REACT_APP_NAME=ASPES
REACT_APP_FULL_NAME=AI Smart Academic Project Evaluation System
REACT_APP_VERSION=1.0.0

# Feature flags
REACT_APP_ENABLE_DEMO_MODE=false
REACT_APP_ENABLE_ANALYTICS=false

# Google Analytics (optional)
REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry (optional - for error tracking)
REACT_APP_SENTRY_DSN=

# Upload limits (must match backend)
REACT_APP_MAX_UPLOAD_SIZE_MB=50
