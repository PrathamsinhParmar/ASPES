# ==============================================================================
# AI Smart Academic Project Evaluation System (ASPES)
# Backend Environment Configuration Template
# Copy this file to .env and fill in your actual values
# ==============================================================================

# ------------------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------------------
APP_NAME="ASPES - AI Smart Academic Project Evaluation System"
APP_VERSION="1.0.0"
DEBUG=False
ENVIRONMENT=development  # development | staging | production

# Secret key for JWT token signing (generate with: openssl rand -hex 32)
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------------------------
# Database Configuration (PostgreSQL 15+)
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://aspes_user:aspes_password@localhost:5432/aspes_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=aspes_db
DATABASE_USER=aspes_user
DATABASE_PASSWORD=aspes_password

# Connection Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ------------------------------------------------------------------------------
# Redis Configuration (for Celery task queue & caching)
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_TIMEOUT=3600
CELERY_WORKER_CONCURRENCY=4

# ------------------------------------------------------------------------------
# AI / ML Configuration
# ------------------------------------------------------------------------------
# Gemini API (for LLM-based feedback generation)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=2000
GEMINI_TEMPERATURE=0.7

# Sentence-BERT Model (used for semantic similarity & plagiarism detection)
SBERT_MODEL_NAME=all-MiniLM-L6-v2
SBERT_CACHE_DIR=./models/sbert

# HuggingFace Token (for private/gated models)
HUGGINGFACE_TOKEN=hf_your-token-here

# AI Code Detection Threshold (0.0 - 1.0)
AI_CODE_DETECTION_THRESHOLD=0.75

# Plagiarism Detection Threshold (0.0 - 1.0)
PLAGIARISM_THRESHOLD=0.80

# ------------------------------------------------------------------------------
# File Upload Configuration
# ------------------------------------------------------------------------------
MAX_UPLOAD_SIZE=52428800      # 50 MB in bytes
ALLOWED_EXTENSIONS=pdf,docx,py,java,cpp,c,js,ts,zip,tar.gz
UPLOAD_DIR=./uploads
TEMP_DIR=./uploads/temp

# ------------------------------------------------------------------------------
# CORS Configuration
# ------------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
ALLOWED_HEADERS=*

# ------------------------------------------------------------------------------
# Email Configuration (SMTP)
# ------------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=True
FROM_EMAIL=noreply@aspes.edu
FROM_NAME=ASPES System

# ------------------------------------------------------------------------------
# Storage Configuration (local or S3-compatible)
# ------------------------------------------------------------------------------
STORAGE_BACKEND=local   # local | s3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_BUCKET_NAME=aspes-uploads
AWS_REGION=us-east-1
S3_ENDPOINT_URL=        # For MinIO or other S3-compatible: http://localhost:9000

# ------------------------------------------------------------------------------
# Security & Rate Limiting
# ------------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
PASSWORD_MIN_LENGTH=8
BCRYPT_ROUNDS=12

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json          # json | text
LOG_FILE=./logs/aspes.log

# ------------------------------------------------------------------------------
# Frontend URL (for email links, CORS, etc.)
# ------------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
