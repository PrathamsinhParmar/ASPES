# ==============================================================================
# Python / FastAPI Backend .gitignore
# ==============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST
*.pyc
*.pyo
*.pyd

# Virtual Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version

# Environment Variables (IMPORTANT - never commit!)
.env
.env.*
!.env.example

# Database
*.db
*.sqlite
*.sqlite3

# Uploads folder (user content - don't commit)
uploads/
!uploads/.gitkeep

# Logs
logs/
*.log

# ML Model cache (large files)
models/
*.bin
*.pt
*.pth
*.onnx

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.DS_Store

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# Distribution / packaging
.Python
pip-wheel-metadata/

# Celery
celerybeat-schedule
celerybeat.pid

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Alembic
# (keep migrations/ but ignore auto-generated)

# Temporary files
*.tmp
*.bak
*.swp
~$*

# OS-specific
Thumbs.db
.DS_Store
