# ASPES - Backend Environment Configuration

# --- App Settings ---
APP_NAME="ASPES - AI Smart Academic Project Evaluation System"
ENVIRONMENT="development"
DEBUG=True
LOG_LEVEL="INFO"

# --- Security ---
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY="replace-this-with-a-very-secure-random-hex-string"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database ---
# Local SQLite for quick development (use PostgreSQL in production)
DATABASE_URL="postgresql+asyncpg://aspes_user:aspes_pass@localhost:5432/aspes_db"

# --- Redis & Celery ---
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"

# --- AI Engine API Keys ---
# Replace with your actual Gemini API Key from Google AI Studio
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# Optional: Fallback to OpenAI if desired (feature implemented in feedback_generator.py)
OPENAI_API_KEY="optional-openai-key"

# --- Cross-Origin Resource Sharing (CORS) ---
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:8080"

# --- File Storage ---
UPLOAD_DIR="./uploads"
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes

# --- SBERT Settings ---
SBERT_MODEL_NAME="all-MiniLM-L6-v2"
SBERT_CACHE_DIR="./models/sbert"
