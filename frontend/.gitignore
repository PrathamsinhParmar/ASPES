# ==============================================================================
# React / Node.js Frontend .gitignore
# ==============================================================================

# Dependencies
node_modules/
/.pnp
.pnp.js

# Production builds
/build
/dist

# Environment Variables (IMPORTANT - never commit!)
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# Testing
/coverage

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Misc
.cache/
.parcel-cache/
